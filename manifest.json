{
  "manifest_version": 3,
  "name": "Save to Google Photos",
  "version": "0.1.0",
  "description": "Right-click any image and save it to Google Photos.",
  "key": "",
  "background": {
    "service_worker": "dist/sw.js",
    "type": "module"
  },
  "permissions": ["contextMenus", "identity", "notifications", "storage"],
  "host_permissions": [
    "https://photoslibrary.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "oauth2": {
    "client_id": "478240865692-d14npticheu6si2cqjbm5cbehal1j91l.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/photoslibrary.appendonly"]
  }
}
