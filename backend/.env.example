# Required for OAuth code exchange
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/v1/auth/callback

# Optional (defaults shown)
PORT=8080
GOOGLE_SCOPES=https://www.googleapis.com/auth/photoslibrary.appendonly openid email
# CORS_ORIGIN=chrome-extension://<your-extension-id>
# CORS_ORIGIN=chrome-extension://<your-extension-id>,http://localhost:3000
# ALLOWED_GOOGLE_USER_ID=123456789012345678901
# SESSION_TTL_MS=900000
# AUTH_STATE_TTL_MS=300000
# EXCHANGE_CODE_TTL_MS=120000
# MAX_UPLOAD_BYTES=26214400

# Required only for Cloudflare runtime when AUTH_KV and APP_DB bindings are set
# Generate with: openssl rand -base64 32
# TOKEN_ENCRYPTION_KEY=
